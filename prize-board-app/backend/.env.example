NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/prize_board
REDIS_URL=redis://redis:6379
QUEUE_REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-a-32-plus-character-jwt-secret-value
JWT_REFRESH_SECRET=replace-with-a-32-plus-character-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
FIREBASE_SERVER_KEY=firebase_server_key

# Comma-separated explicit origins (e.g. https://swipe2win.vercel.app,https://admin.example.com)
CORS_ORIGIN=https://swipe2win.app
# Optional primary Vercel frontend domain
VERCEL_FRONTEND_URL=

