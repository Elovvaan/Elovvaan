name: Set Fly.io Secrets

on:
  workflow_dispatch:
    inputs:
      jwt_secret:
        description: 'JWT Secret for authentication'
        required: true
        type: string
      stripe_secret_key:
        description: 'Stripe Secret Key'
        required: false
        type: string
      stripe_webhook_secret:
        description: 'Stripe Webhook Secret'
        required: false
        type: string

jobs:
  set-secrets:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Install Fly CLI
        run: curl -L https://fly.io/install.sh | sh
      
      - name: Set JWT_SECRET
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          ~/.fly/bin/flyctl secrets set JWT_SECRET="${{ github.event.inputs.jwt_secret }}" -a elovvaan
      
      - name: Set STRIPE_SECRET_KEY (if provided)
        if: github.event.inputs.stripe_secret_key != ''
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          ~/.fly/bin/flyctl secrets set STRIPE_SECRET_KEY="${{ github.event.inputs.stripe_secret_key }}" -a elovvaan
      
      - name: Set STRIPE_WEBHOOK_SECRET (if provided)
        if: github.event.inputs.stripe_webhook_secret != ''
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          ~/.fly/bin/flyctl secrets set STRIPE_WEBHOOK_SECRET="${{ github.event.inputs.stripe_webhook_secret }}" -a elovvaan
      
      - name: Redeploy application
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          ~/.fly/bin/flyctl deploy -a elovvaan
